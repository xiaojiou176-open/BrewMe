{
  "name": "@brewme/sdk",
  "version": "0.1.12",
  "description": "Thin public TypeScript SDK for the BrewMe HTTP API.",
  "homepage": "https://xiaojiou176-open.github.io/brewme/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaojiou176-open/brewme.git"
  },
  "bugs": {
    "url": "https://github.com/xiaojiou176-open/brewme/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "brewme",
    "sdk",
    "typescript",
    "mcp",
    "retrieval",
    "knowledge-pipeline"
  ],
  "scripts": {
    "build": "npx --yes -p typescript tsc -p tsconfig.build.json",
    "typecheck": "npx --yes -p typescript tsc -p tsconfig.build.json --noEmit",
    "pack:dry": "npm pack --dry-run"
  }
}
