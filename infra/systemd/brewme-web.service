[Unit]
Description=BrewMe - Next.js Web Frontend
After=network.target brewme-api.service

[Service]
Type=simple
User=brewme
Group=brewme
WorkingDirectory=/opt/brewme/repo/apps/web
EnvironmentFile=/opt/brewme/.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run start -- --port 3001
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=brewme-web

NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
