#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=./scripts/runtime/entrypoint.sh
source "$ROOT_DIR/scripts/runtime/entrypoint.sh"
brewme_entrypoint_bootstrap governance strict-ci "" "$@"

if "$ROOT_DIR/scripts/strict_ci_entry.sh" "$@"; then
  brewme_log info complete "PASS"
  exit 0
else
  status=$?
  brewme_log error complete "FAIL exit_code=$status"
  exit "$status"
fi
