#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=./scripts/runtime/entrypoint.sh
source "$ROOT_DIR/scripts/runtime/entrypoint.sh"
brewme_entrypoint_bootstrap runtime stop-repo-chrome "" "$@"
exec python3 "$ROOT_DIR/scripts/runtime/stop_repo_chrome.py" "$@"
